{
  "name": "meshchain",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start":   "expo start",
    "android": "expo start --android",
    "ios":     "expo start --ios",
    "test":    "jest --watchAll",
    "test:ci": "jest --ci --coverage"
  },
  "dependencies": {
    "expo":                           "~50.0.0",
    "expo-status-bar":                "~1.11.1",
    "expo-location":                  "~16.5.2",
    "expo-battery":                   "~12.8.1",
    "expo-sqlite":                    "~13.4.0",
    "expo-secure-store":              "~12.8.1",
    "react":                          "18.2.0",
    "react-native":                   "0.73.2",
    "react-native-ble-plx":           "^3.1.2",
    "react-native-wifi-p2p":          "^1.2.3",
    "react-native-get-random-values": "~1.11.0",
    "crypto-js":                      "^4.2.0",
    "tweetnacl":                      "^1.0.3",
    "tweetnacl-util":                 "^0.15.1",
    "uuid":                           "^9.0.0",
    "buffer":                         "^6.0.3",
    "events":                         "^3.3.0"
  },
  "devDependencies": {
    "@babel/core":                    "^7.20.0",
    "@types/react":                   "~18.2.45",
    "jest":                           "^29.7.0",
    "jest-expo":                      "~50.0.1",
    "@testing-library/react-native":  "^12.4.0",
    "typescript":                     "^5.3.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|tweetnacl|tweetnacl-util|uuid|crypto-js|buffer|events)"
    ],
    "moduleNameMapper": {
      "^react-native-get-random-values$": "<rootDir>/__mocks__/react-native-get-random-values.js",
      "^react-native-ble-plx$":           "<rootDir>/__mocks__/react-native-ble-plx.js",
      "^react-native-wifi-p2p$":          "<rootDir>/__mocks__/react-native-wifi-p2p.js",
      "^expo-secure-store$":              "<rootDir>/__mocks__/expo-secure-store.js",
      "^expo-sqlite$":                    "<rootDir>/__mocks__/expo-sqlite.js",
      "^expo-location$":                  "<rootDir>/__mocks__/expo-location.js",
      "^expo-battery$":                   "<rootDir>/__mocks__/expo-battery.js"
    }
  }
}
